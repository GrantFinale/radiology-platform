{
  "name": "radiology-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Radiology Interoperability Platform — order intake, normalization, and scheduling readiness",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "packages/shared",
    "services/api-gateway",
    "services/order-service",
    "services/document-service",
    "services/integration-service",
    "apps/review-ui"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:shared": "npm run build -w packages/shared",
    "build:services": "npm run build -w services/api-gateway -w services/order-service -w services/document-service -w services/integration-service",
    "build:ui": "npm run build -w apps/review-ui",
    "dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "start": "docker compose up -d",
    "stop": "docker compose down",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "migrate": "npm run migrate -w services/order-service",
    "migrate:create": "npm run migrate:create -w services/order-service",
    "migrate:reset": "npm run migrate:reset -w services/order-service",
    "seed": "npm run seed -w services/order-service",
    "prisma:generate": "npm run prisma:generate -w services/order-service",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v && docker compose up -d"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
