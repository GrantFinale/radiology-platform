# ============================================================
# Radiology Interoperability Platform — Environment Variables
# ============================================================
# Copy this file to .env and update values for your environment.
# All variables have sensible defaults for local development.
# IMPORTANT: Change all secrets before deploying to production.

# ── General ──────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info                          # debug | info | warn | error
LOG_FORMAT=json                         # json | pretty

# ── Service Ports (host-side) ────────────────────────────────
API_GATEWAY_PORT=3000
REVIEW_UI_PORT=3005
MLLP_PORT=2575

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=rip
POSTGRES_PASSWORD=rip_secret            # CHANGE IN PRODUCTION
POSTGRES_DB=radiology_platform
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret             # CHANGE IN PRODUCTION
REDIS_PORT=6379
REDIS_MAX_MEMORY=512mb

# ── MinIO (S3-compatible Object Storage) ─────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minio_secret           # CHANGE IN PRODUCTION
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_BACKUPS=backups
MINIO_SERVER_URL=http://minio:9000

# ── Authentication ───────────────────────────────────────────
JWT_SECRET=change-me-in-production      # CHANGE IN PRODUCTION — min 32 chars
JWT_EXPIRY=1h
SERVICE_SECRET=inter-service-secret     # CHANGE IN PRODUCTION — HMAC key for service-to-service auth

# ── Order Processing ────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.85               # NLP confidence threshold for auto-approval (0.0–1.0)
REVIEW_SLA_HOURS=4                      # Hours before a review task is flagged as overdue

# ── Document Service ────────────────────────────────────────
OCR_CONCURRENCY=2                       # Number of concurrent OCR workers
MAX_FILE_SIZE_MB=50                     # Maximum upload file size in MB
DOCUMENT_RETENTION_DAYS=90              # Days before archived documents are purged

# ── NLP Service ─────────────────────────────────────────────
SPACY_MODEL=en_core_web_lg              # spaCy model (en_core_web_sm for dev, en_core_web_lg for prod)
NLP_BATCH_SIZE=10                       # Number of documents to process in a batch
NLP_WORKERS=2                           # Number of uvicorn workers

# ── Integration Service ─────────────────────────────────────
MLLP_TIMEOUT_MS=30000                   # MLLP connection timeout
WEBHOOK_RETRY_ATTEMPTS=5                # Max webhook delivery retries
WEBHOOK_RETRY_BACKOFF_MS=1000           # Initial backoff between retries (exponential)
FHIR_SERVER_BASE=                       # External FHIR server URL (optional)

# ── API Gateway ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000              # Rate limit window (ms)
RATE_LIMIT_MAX_REQUESTS=100             # Max requests per window per client
CORS_ORIGIN=http://localhost:3005       # Allowed CORS origin

# ── Review UI ───────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_WS_URL=ws://localhost:3000/ws
VITE_SESSION_TIMEOUT_MINUTES=15
